sequenceDiagram
actor Client as User
participant API as Presentation(API)
participant Facade as HBnBFacade
participant BLL as BusinessLogic(ReviewService)
participant PlaceRepo as Persistence(PlaceRepository)
participant UserRepo as Persistence(UserRepository)
participant ReviewRepo as Persistence(ReviewRepository)

Client->>API: POST /places/{place_id}/reviews {rating,comment}
API->>API: AuthN/AuthZ + validate payload
API->>Facade: submit_review(user_id, place_id, data)

Facade->>BLL: submit_review(user_id, place_id, data)

BLL->>PlaceRepo: get_by_id(place_id)
PlaceRepo-->>BLL: place / null

alt place not found
  BLL-->>Facade: Error: PlaceNotFound
  Facade-->>API: 404 Not Found
  API-->>Client: 404 {error}
else place ok
  BLL->>UserRepo: get_by_id(user_id)
  UserRepo-->>BLL: user / null

  alt user not found
    BLL-->>Facade: Error: UserNotFound
    Facade-->>API: 404 Not Found
    API-->>Client: 404 {error}
  else ok
    BLL->>BLL: validate_rating(1..5)
    BLL->>BLL: review = Review(user, place, rating, comment)

    BLL->>ReviewRepo: create(review)
    ReviewRepo-->>BLL: saved review (id,timestamps)

    BLL-->>Facade: review DTO
    Facade-->>API: 201 Created
    API-->>Client: 201 {id,rating,comment,user_id,place_id}
  end
end