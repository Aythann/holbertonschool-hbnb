classDiagram

class PresentationLayer {
  <<Layer>>
  API
  Services
}

class HBnBFacade {
  <<Facade>>
  +register_user()
  +create_place()
  +submit_review()
  +list_places()
}

class BusinessLogicLayer {
  <<Layer>>
  Models
  BusinessRules
  Services
}

class PersistenceLayer {
  <<Layer>>
  Repositories
  Storage
}

PresentationLayer --> HBnBFacade : &nbsp calls &nbsp
HBnBFacade --> BusinessLogicLayer : &nbsp orchestrates &nbsp
BusinessLogicLayer --> PersistenceLayer : &nbsp uses (repositories) &nbsp
